</head>\
<body>\
\
  <h1>The Ledger</h1>\
\
  <div class="card" style="border-color: #4caf50;">\
    <h2 style="margin-top: 0; color: #fff;">Weekend Fund</h2>\
    <div style="font-size: 2.5rem; font-weight: bold; color: #4caf50;">\
      $<span id="weekend-fund">0</span>\
    </div>\
  </div>\
\
  <h2>Weekly Operations</h2>\
  <div class="card">\
