<script>\
  // Initialize LocalStorage constraints\
  let weekendFund = parseInt(localStorage.getItem('vantaWeekend')) || 0;\
  let goalCurrent = parseInt(localStorage.getItem('vantaGoal')) || 0;\
  const goalTarget = 200;\
\
  // The engine that renders the truth\
  function updateUI() \{\
    document.getElementById('weekend-fund').innerText = weekendFund;\
    document.getElementById('goal-current').innerText = goalCurrent;\
    \
    // Calculate hydraulic pressure for the progress bar\
    let percent = (goalCurrent / goalTarget) * 100;\
    document.getElementById('goal-bar').style.width = Math.min(percent, 100) + '%';\
    \
    // Trip the valve if target is reached\
    if (goalCurrent >= goalTarget) \{\
      document.getElementById('goal-reward').style.display = 'block';\
    \} else \{\
      document.getElementById('goal-reward').style.display = 'none';\
    \}\
  \}\
\
  // Add standard operational funds\
  function addFund(amount) \{\
    weekendFund += amount;\
    localStorage.setItem('vantaWeekend', weekendFund);\
    updateUI();\
  \}\
\
  // Pump pressure into the long-term goal\
  function pumpAccumulator(amount) \{\
    if (goalCurrent < goalTarget) \{\
      goalCurrent += amount;\
      localStorage.setItem('vantaGoal', goalCurrent);\
      updateUI();\
    \}\
  \}\
\
  // Initial render\
  updateUI();\
</script>\
