  </div>\
  <div class="card">\
    <div class="flex-between">\
      <span class="task-name">Friday Logistics with Kaldur & Skarlette</span>\
      <button class="btn" onclick="addFund(15)">+$15</button>\
    </div>\
  </div>\
\
  <h2>Long-Term Accumulator</h2>\
  <div class="card">\
    <div class="flex-between">\
      <span class="task-name">Save for New Electronics Gear</span>\
      <span style="color: #888;">$<span id="goal-current">0</span> / $200</span>\
